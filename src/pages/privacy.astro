---
import BaseLayout from '@/layouts/base.astro';
import { Navbar } from '@/components/navbar';
---

<BaseLayout title="Privacy Policy | Haloy" description="How Haloy handles analytics and personal data on haloy.dev.">
  <Navbar client:load />
  <main class="mx-auto w-full max-w-3xl px-6 py-12">
    <h1 class="text-4xl font-black tracking-tight">Privacy Policy</h1>
    <p class="mt-3 text-sm text-muted-foreground">Last updated: March 4, 2026</p>

    <section class="mt-10 space-y-3">
      <h2 class="text-2xl font-semibold">Analytics</h2>
      <p class="text-muted-foreground">
        We use Plausible Analytics to understand aggregate site usage. Plausible is cookie-free and does not collect
        personal data such as names, email addresses, or full IP addresses.
      </p>
      <p class="text-muted-foreground">
        Analytics requests are proxied through this domain to improve reliability with privacy tools:
        <code class="mx-1 rounded bg-muted px-1.5 py-0.5 text-xs">/pls/js/script.js</code>
        and
        <code class="mx-1 rounded bg-muted px-1.5 py-0.5 text-xs">/pls/api/event</code>.
      </p>
    </section>

    <section class="mt-8 space-y-3">
      <h2 class="text-2xl font-semibold">Newsletter</h2>
      <p class="text-muted-foreground">
        If you subscribe to the newsletter, we collect your email address to send updates. You can unsubscribe at any
        time from the link in any email.
      </p>
    </section>

    <section class="mt-8 space-y-3">
      <h2 class="text-2xl font-semibold">Contact</h2>
      <p class="text-muted-foreground">
        For privacy questions, open an issue at
        <a
          href="https://github.com/haloydev/haloy"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 underline decoration-muted-foreground/50 underline-offset-4 hover:decoration-foreground"
        >
          github.com/haloydev/haloy
        </a>.
      </p>
    </section>
  </main>
</BaseLayout>
